# ===========================================
# Rounds — Environment Variables
# ===========================================
# Copy to .env.local and fill in values

# --- Neon Postgres (via Vercel integration) ---
POSTGRES_URL="postgres://..."

# --- Custom Auth (JWT) ---
JWT_SECRET="generate-with-openssl-rand-base64-64"

# --- App Config ---
NEXT_PUBLIC_APP_NAME="Rounds"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Resend (Phase 2: magic link login) ---
# RESEND_API_KEY="re_..."

# --- Pusher (Phase 2: realtime) ---
# PUSHER_APP_ID="..."
# PUSHER_KEY="..."
# PUSHER_SECRET="..."
# PUSHER_CLUSTER="ap2"

# --- Vercel Blob (Phase 2: file uploads) ---
# BLOB_READ_WRITE_TOKEN="..."

# --- Claude API (Phase 4) ---
# ANTHROPIC_API_KEY="sk-ant-..."
