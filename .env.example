# ===========================================
# Rounds — Environment Variables
# ===========================================
# Copy to .env.local and fill in values

# --- Neon Postgres (via Vercel integration) ---
# These are auto-injected by the Vercel-Neon integration.
# For local dev, copy POSTGRES_URL from your Neon dashboard.
POSTGRES_URL="postgres://..."

# --- Custom Auth (JWT) ---
JWT_SECRET="generate-with-openssl-rand-base64-64"

# --- GetStream Chat ---
NEXT_PUBLIC_GETSTREAM_API_KEY="ekbhy4vctj9g"
GETSTREAM_API_SECRET="your-getstream-api-secret-from-dashboard"

# --- LeadSquared CRM Integration ---
LSQ_ACCESS_KEY="your-leadsquared-access-key"
LSQ_SECRET_KEY="your-leadsquared-secret-key"
LSQ_API_HOST="https://api-in21.leadsquared.com/v2"
LSQ_WEBHOOK_SECRET="your-webhook-shared-secret"

# --- Cron Job Protection ---
# Required for /api/integrations/leadsquared/sync and /api/escalation/cron
CRON_SECRET="generate-a-random-secret"

# --- LLM / AI (Ollama via Cloudflare Tunnel) ---
LLM_BASE_URL="http://localhost:11434/v1"
LLM_API_KEY="ollama"

# --- Vercel Blob (file uploads) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# --- Web Push Notifications (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:tech@even.in"
